# Django Settings
SECRET_KEY=your-secret-key
DEBUG=False
ZBPACK_START_COMMAND=gunicorn config.wsgi:application --bind 0.0.0.0:$PORT

# Database Settings
# For SQLite (local)
# For PostgreSQL (production):
POSTGRES_CONNECTION_STRING=postgres://user:password@host:port/dbname

# Redis Settings
REDIS_URI=redis://127.0.0.1:6379/1

# URLs and Security
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8000,http://127.0.0.1:8000

# Frontend URL
FRONTEND_URL=http://localhost:8080

# Dify API Settings
DIFY_API_KEY=your-dify-api-key
DIFY_API_URL=https://api.dify.ai/v1

# Environment
DJANGO_ENV=local

# Google Authentication
SOCIAL_AUTH_GOOGLE_CLIENT_ID=your-google-client-id
ALLOWED_EMAIL_DOMAINS=gm.ntpu.edu.tw