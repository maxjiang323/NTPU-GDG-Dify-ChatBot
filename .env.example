# Django Settings
SECRET_KEY=your-secret-key
DEBUG=False
ZBPACK_START_COMMAND=gunicorn config.wsgi:application --bind 0.0.0.0:$PORT

# Database Settings
# For SQLite (local)
# For PostgreSQL (production):
POSTGRES_CONNECTION_STRING=postgres://user:password@host:port/dbname

# Redis Settings
REDIS_URI=redis://127.0.0.1:6379/1

# URLs and Security
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Dify API Settings
DIFY_API_KEY=your-dify-api-key
DIFY_API_URL=https://api.dify.ai/v1

# Environment
DJANGO_ENV=local

# Security - Allowed email domains for Google Login (comma separated)
ALLOWED_EMAIL_DOMAINS=mail.ntpu.edu.tw,gm.ntpu.edu.tw
